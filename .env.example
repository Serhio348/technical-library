# Technical Library — environment

LIBRARY_PORT=3021
LIBRARY_ROOT=./data/library

# Опционально: подсказка клиенту (bot/UI), какое направление открыть первым
# DEFAULT_DIRECTION_SLUG=gas
# DEFAULT_SCOPE_PATH=tkp

LIBRARY_SHARED_SECRET=

LIBRARY_MAX_FILE_MB=200
LIBRARY_OCR_MAX_PAGES=150
LIBRARY_OCR_TIMEOUT_SEC=900

LOG_LEVEL=info

# ИИ-чат (DeepSeek API) — вопросы по проиндексированным документам
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Telegram-бот (поиск и вопросы по документам — тот же API, один контейнер)
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_DISABLED=true

# Обход panic docker compose bake на Ubuntu (опционально)
COMPOSE_BAKE=false
