# Technical Library — environment

LIBRARY_PORT=3021
LIBRARY_ROOT=./data/library

# Опционально: подсказка клиенту (bot/UI), какое направление открыть первым
# DEFAULT_DIRECTION_SLUG=gas
# DEFAULT_SCOPE_PATH=tkp

LIBRARY_SHARED_SECRET=

LIBRARY_MAX_FILE_MB=200
# Сколько файлов за один запрос (UI + API)
LIBRARY_UPLOAD_MAX_FILES=20
LIBRARY_OCR_MAX_PAGES=150
LIBRARY_OCR_TIMEOUT_SEC=900
# DPI для pdftoppm: 150 быстрее, 200 точнее
LIBRARY_OCR_DPI=150
# Сколько OCR одновременно (tesseract). На VPS почти всегда 1 — иначе всё зависает.
LIBRARY_OCR_MAX_CONCURRENT=1
# Сколько задач индексации параллельно (Word/TXT могут идти рядом; OCR ждёт слот выше).
# На слабом VPS: 1–2. Не ставьте 4 вместе с OCR, если мало CPU/RAM.
LIBRARY_INDEX_MAX_CONCURRENT=2

LOG_LEVEL=info

# ИИ-чат (DeepSeek API) — вопросы по проиндексированным документам
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Telegram-бот (поиск и вопросы по документам — тот же API, один контейнер)
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_DISABLED=true
# TELEGRAM_API_ROOT=https://api.telegram.org
# HTTPS URL сайта для кнопки Mini App «🎤 Чат с голосом» (как на сайте, с микрофоном в поле)
# TELEGRAM_WEB_APP_URL=https://ваш-домен.ru

# Обход panic docker compose bake на Ubuntu (опционально)
COMPOSE_BAKE=false
